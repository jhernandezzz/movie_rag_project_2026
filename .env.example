# Google Gemini Configuration
# Get your free key at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# TMDB Configuration
# Use the "API Read Access Token" (the long Bearer token) from the TMDB dashboard
TMDB_READ_ACCESS_TOKEN=your_tmdb_bearer_token_here

# Database Configuration
POSTGRES_DB=cinemarag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cinemarag

# Backend Configuration
PORT=8000
